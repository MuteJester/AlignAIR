FROM centos:7


# Install development tools and dependencies, including GCC
RUN yum -y groupinstall "Development tools" \
    && yum -y install wget zlib-devel bzip2-devel openssl-devel ncurses-devel libxml2-devel libxslt-devel readline-devel tk-devel gdbm-devel db4-devel libpcap-devel xz-devel libjpeg-devel gcc gcc-c++ \
    && wget https://developer.download.nvidia.com/compute/cuda/repos/rhel7/x86_64/cuda-rhel7.repo -O /etc/yum.repos.d/cuda.repo \
    && yum clean all

# Download the CUDA installer, install CUDA toolkit silently, download and install cuDNN, and clean up
RUN wget https://developer.download.nvidia.com/compute/cuda/repos/rhel7/x86_64/cuda-rhel7.repo -O /tmp/cuda_installer.run \
    && chmod +x /tmp/cuda_installer.run \
    && /tmp/cuda_installer.run --toolkit --silent \
    && rm /tmp/cuda_installer.run \
    && wget https://developer.download.nvidia.com/compute/machine-learning/repos/rhel7/x86_64/libcudnn8-8.0.4.30-1.cuda11.1.x86_64.rpm \
    && rpm -i libcudnn8-8.0.4.30-1.cuda11.1.x86_64.rpm \
    && yum -y install libcudnn8 \
    && rm libcudnn8-8.0.4.30-1.cuda11.1.x86_64.rpm

# Install Anaconda
RUN wget --quiet --no-check-certificate https://repo.anaconda.com/archive/Anaconda3-2021.11-Linux-x86_64.sh -O /tmp/anaconda.sh \
    && /bin/bash /tmp/anaconda.sh -b -p /opt/conda \
    && rm /tmp/anaconda.sh \
    && /opt/conda/bin/conda init \
    && /opt/conda/bin/conda create -n python39 python=3.9 \
    && yum -y groupremove "Development tools" \
    && yum -y remove wget bzip2 zlib-devel bzip2-devel openssl-devel ncurses-devel libxml2-devel libxslt-devel readline-devel tk-devel gdbm-devel db4-devel libpcap-devel xz-devel libjpeg-devel gcc gcc-c++ \
    && yum clean all

# Set environment variables
ENV PATH="/opt/conda/bin:/opt/conda/envs/python39/bin:$PATH"
ENV LD_LIBRARY_PATH="/opt/conda/envs/python39/lib"

# Setup work directory
RUN mkdir -p /work
WORKDIR /work
COPY . .

# Install Python dependencies
# RUN /opt/conda/bin/conda run -n python39 pip install -e . \
#     && /opt/conda/bin/conda install -n python39 cudatoolkit cudnn \
#     # && /opt/conda/bin/conda install omegaconf
# SHELL ["conda", "run", "-n", "python39", "/bin/bash", "-c"]
# RUN pip install omegaconf

# Install Python dependencies
RUN /opt/conda/bin/conda run -n python39 bash -c "pip install -e . && /opt/conda/bin/conda install -n python39 cudatoolkit cudnn" \
    && pip install omegaconf

# Set the default command to bash
CMD ["/bin/bash"]



