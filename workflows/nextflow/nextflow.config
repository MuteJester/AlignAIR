// AlignAIR Nextflow wrapper DRAFT config.
manifest {
    name        = "alignair-predict"
    description = "AlignAIR per-sample IG/TCR alignment (draft wrapper)"
    mainScript  = "main.nf"
}

// Run with the published container (recommended once available):
//   nextflow run main.nf -profile docker --model <bundle|catalog id> --samplesheet ../samplesheet.csv
profiles {
    docker     { docker.enabled = true }
    singularity { singularity.enabled = true }
    local      { process.container = null }   // use a local `alignair` already on PATH
}

process {
    cpus = 4
    memory = "8 GB"
}
